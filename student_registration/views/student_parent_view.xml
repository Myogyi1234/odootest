<odoo>
    <!-- ───── Tree View ───── -->
    <record id="view_student_parent_tree" model="ir.ui.view">
        <field name="name">student.parent.tree</field>
        <field name="model">student.parent</field>
        <field name="arch" type="xml">
            <tree string="Parent Information">
                <field name="name"/>
                <field name="nrc_no"/>
                <field name="relation"/>
                <field name="phone_number"/>
                <field name="student_count"/>
            </tree>
        </field>
    </record>

    <!-- ───── Form View ───── -->
    <record id="view_student_parent_form" model="ir.ui.view">
        <field name="name">student.parent.form</field>
        <field name="model">student.parent</field>
        <field name="arch" type="xml">
            <form string="Parent Information">
                <sheet>

                    <!-- Smart Button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-graduation-cap"
                                invisible="student_count == 0">
                            <field name="student_count"
                                   widget="statinfo"
                                   string="Students"/>
                        </button>
                    </div>

                    <!-- အခြေခံ အချက်အလက် -->
                    <group string="Personal Information">
                        <group>
                            <field name="name"/>
                            <field name="nrc_no"
                                   placeholder="5/KaBaLa(NAING)262100 (or) ၁၂/မရက(နိုင်)၁၂၃၄၅၆"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                        </group>
                        <group>

                            <field name="relation"/>
                        </group>
                    </group>

                    <!-- အလုပ်အကိုင် အချက်အလက် -->
                    <group string="Job Information">
                        <group>
                            <field name="job_title"/>
                            <field name="monthly_income"/>
                            <field name="workplace"/>
                        </group>
                    </group>

                    <!-- ဆက်သွယ်ရေး အချက်အလက် -->
                    <group string="Contact Address">
                        <group>
                            <field name="email"/>
                            <field name="phone_number"/>
                            <field name="address"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ───── Action ───── -->
    <record id="action_student_parent" model="ir.actions.act_window">
        <field name="name">Parents</field>
        <field name="res_model">student.parent</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ───── Menu ───── -->
    <menuitem id="menu_student_parent"
              name="Parents"
              parent="menu_student_root"
              action="action_student_parent"
              sequence="3"/>
</odoo>